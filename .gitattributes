# Pastikan shell scripts selalu disimpan dengan Unix line endings (LF)
# agar bisa dieksekusi di Linux container (Docker/Railway)
*.sh text eol=lf

# File teks umum
*.php text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.sql text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf

# File biner — jangan ubah line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary
